# Cloudflare AI Gateway
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_GATEWAY_ID=

# Google AI Studio (Gemini search grounding)
# Multi-key pool: GOOGLE_API_KEY_1 to GOOGLE_API_KEY_10
# Single key fallback: GEMINI_API_KEY
GOOGLE_API_KEY_1=
GOOGLE_API_KEY_2=
GEMINI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro

# Exa Search
EXA_API_KEY=

# MiniMax Search
MMX_API_KEY=
MMX_REGION=cn
# MMX_BASE_URL=https://api.minimaxi.com  # optional override

# Kimi (Moonshot)
KIMI_API_KEY=
KIMI_BASE_URL=https://api.kimi.com/coding/v1
KIMI_MODEL=kimi-k2.6

# MiMo (Xiaomi)
MIMO_API_KEY=
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro

# Search Provider (exa|mmx|gemini)
SEARCH_PROVIDER=exa
SEARCH_MAX_RESULTS=5

# Web Fetch Provider (mineru|gemini|cloudflare)
FETCH_PROVIDER=mineru
FETCH_MAX_LENGTH=30000
FETCH_LLM_MODEL=gemini-2.5-flash-lite
FETCH_LLM_BASE_URL=
FETCH_LLM_API_KEY=

# Agentic Loop
MAX_AGENTIC_ROUNDS=3

# Server
PORT=3000
DEBUG=false
